<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="NlkFtpReports.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
    <script>
        (function() {
            var saved = localStorage.getItem('nlk-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', saved);
            var bg = saved === 'light' ? '#f5f5f8' : '#0b0b12';
            var text = saved === 'light' ? 'rgba(0,0,0,0.25)' : 'rgba(255,255,255,0.25)';
            var textHigh = saved === 'light' ? 'rgba(0,0,0,0.85)' : 'rgba(255,255,255,0.85)';
            var s = document.createElement('style');
            s.textContent = '#fmc-preloader{background-color:' + bg + ';color:' + textHigh + '}' +
                '.preloader-from{color:' + text + '}' +
                '.preloader-brand{color:' + textHigh + '}';
            document.head.appendChild(s);
        })();
    </script>
</head>
<body>

    @* ── Splash Screen ── *@
    @* Removed from DOM by JS after 1.5s *@
    <div id="fmc-preloader">
        <div class="preloader-content">
            <img src="nlkLogo.png" alt="NLK Logo" class="preloader-logo" />
        </div>
        <div class="preloader-footer">
            <span class="preloader-from">from</span>
            <span class="preloader-brand">Nationlink/INFOSERVE</span>
        </div>
    </div>

    <Routes @rendermode="RenderMode.InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script>
        console.log('[Splash] Script loaded at', new Date().toISOString());
        setTimeout(function() {
            var el = document.getElementById('fmc-preloader');
            console.log('[Splash] hiding preloader, found=' + !!el);
            if (el) {
                el.classList.add('hidden');
                setTimeout(function() {
                    if (el.parentNode) {
                        el.parentNode.removeChild(el);
                        console.log('[Splash] DOM element removed');
                    }
                }, 600);
            }
        }, 1500);

        window.fmcFind = {
            _debounce: null,
            _pending: 0,
            highlight: function (text, flags) {
                try {
                var pres = document.querySelectorAll('.viewer-panel .viewer-content pre');
                var empty = { left: 0, right: 0 };
                if (!pres.length) return empty;
                this.clear();
                if (!text) return empty;

                var self = this;
                var id = ++self._pending;
                return new Promise(function(resolve) {
                    self._debounce = setTimeout(function() {
                        try {
                        if (id !== self._pending) { resolve(empty); return; }
                        var counts = [0, 0];
                        var caseSense = flags.indexOf('i') === -1;
                        var wholeWord = flags.indexOf('w') !== -1;
                        var isRegex = flags.indexOf('r') !== -1;

                        pres.forEach(function(pre, panelIdx) {
                            if (!pre || !pre.parentNode) return;
                            var lines = pre.querySelectorAll('span.ln');
                            if (!lines.length) return;

                            if (!pre.hasAttribute('data-original')) {
                                var origHtml = '';
                                lines.forEach(function(s) { origHtml += s.outerHTML + '\n'; });
                                pre.setAttribute('data-original', origHtml);
                            }

                            var pattern = text;
                            if (!isRegex) {
                                pattern = pattern.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                            }
                            if (wholeWord) {
                                pattern = '\\b' + pattern + '\\b';
                            }
                            var re = new RegExp('(' + pattern + ')', caseSense ? 'g' : 'gi');

                            lines.forEach(function(span) {
                                try {
                                if (!span || !span.parentNode) return;
                                re.lastIndex = 0;
                                var lineText = span.textContent || span.innerText;
                                if (re.test(lineText)) {
                                    re.lastIndex = 0;
                                    var marked = lineText.replace(re, '<mark class="fmc-match">$1</mark>');
                                    span.innerHTML = marked;
                                    span.innerHTML = '<mark class="fmc-line">' + span.innerHTML + '</mark>';
                                    counts[panelIdx]++;
                                }
                                } catch(e) {}
                            });
                        });
                        resolve({ left: counts[0], right: counts[1] });
                        } catch(e) { resolve(empty); }
                    }, 120);
                });
                } catch(e) { return { left: 0, right: 0 }; }
            },
            goTo: function (index) {
                try {
                var marks = document.querySelectorAll('.fmc-line');
                if (!marks.length || index >= marks.length) return;
                marks.forEach(function(m) { m.classList.remove('fmc-active'); });
                var target = marks[index];
                if (!target) return;
                target.classList.add('fmc-active');
                var panel = target.closest('.viewer-panel');
                if (panel) {
                    var content = panel.querySelector('.viewer-content');
                    if (content) {
                        content.scrollTop = target.offsetTop - content.clientHeight / 2;
                    }
                }
                } catch(e) {}
            },
            clear: function () {
                try {
                if (this._debounce) { clearTimeout(this._debounce); this._debounce = null; }
                this._pending++;
                var pres = document.querySelectorAll('.viewer-panel pre.pre-line-numbers');
                pres.forEach(function(pre) {
                    try {
                    if (!pre || !pre.parentNode) return;
                    var orig = pre.getAttribute('data-original');
                    if (orig) {
                        pre.innerHTML = orig;
                        pre.removeAttribute('data-original');
                    }
                    } catch(e) {}
                });
                } catch(e) {}
            },
            getScrollPos: function (panelIndex) {
                try {
                var pres = document.querySelectorAll('.viewer-panel .viewer-content');
                var content = panelIndex !== undefined && pres[panelIndex] ? pres[panelIndex] : pres[0];
                if (!content) return [0, 0];
                var scrollTop = content.scrollTop;
                var scrollH = content.scrollHeight - content.clientHeight;
                if (scrollH <= 0) return [0, 0];
                var pct = Math.round((scrollTop / scrollH) * 100);
                var ln = content.querySelector('span.ln');
                if (!ln) return [0, pct];
                var lineH = ln.offsetHeight || 16;
                var line = Math.round(scrollTop / lineH) + 1;
                return [line, pct];
                } catch(e) { return [0, 0]; }
            },
            goToLine: function (lineNum) {
                try {
                var pre = document.querySelector('.viewer-panel .viewer-content pre');
                if (!pre) return;
                var target = pre.querySelector('span.ln[data-line="' + lineNum + '"]');
                if (!target) return;
                var content = pre.closest('.viewer-content');
                if (content) {
                    content.scrollTop = target.offsetTop - content.clientHeight / 3;
                }
                } catch(e) {}
            }
        };
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                var input = document.getElementById('find-input');
                if (input && document.activeElement === input) {
                    input.value = '';
                    input.blur();
                    window.fmcFind.clear();
                    var event = new Event('input', { bubbles: true });
                    input.dispatchEvent(event);
                }
            }
        });

        (function() {
            document.addEventListener('mousedown', function(e) {
                var handle = e.target.closest('.resize-handle, .viewer-divider');
                if (!handle) return;
                e.preventDefault();

                var target;
                var minW = 120, maxW = 600;

                if (handle.classList.contains('viewer-divider')) {
                    target = handle.previousElementSibling;
                    minW = 100; maxW = 2000;
                } else {
                    target = handle.previousElementSibling;
                }

                if (!target) return;
                var startX = e.clientX;
                var startW = target.offsetWidth;

                function onMove(ev) {
                    var dx = ev.clientX - startX;
                    var w = Math.max(minW, Math.min(maxW, startW + dx));
                    target.style.width = w + 'px';
                    target.style.minWidth = w + 'px';
                    target.style.flexShrink = '0';
                }
                function onUp() {
                    document.removeEventListener('mousemove', onMove);
                    document.removeEventListener('mouseup', onUp);
                    document.body.style.cursor = '';
                    document.body.style.userSelect = '';
                }
                document.addEventListener('mousemove', onMove);
                document.addEventListener('mouseup', onUp);
                document.body.style.cursor = 'col-resize';
                document.body.style.userSelect = 'none';
            });
        })();

        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 'f') {
                var input = document.getElementById('find-input');
                if (input) {
                    e.preventDefault();
                    input.focus();
                    input.select();
                }
            }
        });

        window.NlkTheme = {
            get: function () { return localStorage.getItem('nlk-theme') || 'dark'; },
            set: function (t) { localStorage.setItem('nlk-theme', t); document.documentElement.setAttribute('data-theme', t); },
            apply: function (t) { document.documentElement.setAttribute('data-theme', t); }
        };
    </script>
</body>
</html>
