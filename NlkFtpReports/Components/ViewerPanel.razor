@* ── Reusable file preview panel ── *@
<div class="viewer-panel">
    <div class="viewer-header" style="height:auto;min-height:40px;padding:0;">
        @if (Tab != null)
        {
            <div style="display:flex;flex-direction:column;width:100%;min-width:0;">
                <div style="font-size:0.65rem;color:var(--text-muted);padding:3px 16px 0;height:20px;display:flex;align-items:center;gap:6px;">
                    @if (OpenTabs != null && OpenTabs.Count > 1)
                    {
                        <select class="tab-select" @onchange="OnLeftTabSelected" style="font-size:0.6rem;padding:0 4px;max-width:200px;">
                            @foreach (var (t, i) in OpenTabs.Select((t, i) => (t, i)))
                            {
                                <option value="@i" selected="@(Tab?.Key == t.Key)">@t.FileName</option>
                            }
                        </select>
                    }
                    else
                    {
                        <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@Tab.FileName</span>
                    }
                </div>
                @if (Tab.Content != null)
                {
                    <div style="display:flex;align-items:center;gap:4px;padding:2px 12px 2px 16px;">
                        <div class="find-bar" style="flex:1;min-width:0;">
                            <span class="find-label">&#x1F50D;</span>
                            <input type="text" placeholder="Find..."
                                   @bind="_findText" @bind:after="DoFind" @bind:event="oninput"
                                   @onkeydown="OnFindKeyDown" />
                            <span style="margin-left:auto;display:flex;align-items:center;gap:4px;flex-shrink:0;">
                                @if (_isSearching)
                                {
                                    <span class="find-count searching">
                                        <span class="search-spinner"></span> Searching...
                                    </span>
                                }
                                else if (_findCount > 0)
                                {
                                    <span class="find-count">
                                        @if (IsRightPanel && RightMatchCount > 0)
                                        {
                                            <text>@(_findIndex + 1)/@(_findCount) (L:@_findCount R:@RightMatchCount)</text>
                                        }
                                        else
                                        {
                                            <text>@(_findIndex + 1)/@(_findCount)</text>
                                        }
                                    </span>
                                    <button class="btn-icon find-nav" @onclick="FindPrev" title="Previous (Shift+Enter / F3)">&#x25B2;</button>
                                    <button class="btn-icon find-nav" @onclick="FindNext" title="Next (Enter / F3)">&#x25BC;</button>
                                }
                                else if (_findText != "")
                                {
                                    <span class="find-count no-match">No matches</span>
                                }
                                <span style="display:flex;align-items:center;gap:2px;">
                                    <button class="find-mode @(_caseSensitive ? "active" : "")" @onclick="Search.ToggleCase" title="Case sensitive">Aa</button>
                                    <button class="find-mode @(_wholeWord ? "active" : "")" @onclick="Search.ToggleWord" title="Whole word">^w</button>
                                    <button class="find-mode @(_regexMode ? "active" : "")" @onclick="Search.ToggleRegex" title="Regex">.*</button>
                                </span>
                            </span>
                        </div>
                        <div class="viewer-zoom" style="flex-shrink:0;">
                            <button class="btn-icon zoom-btn" @onclick="OnZoomOut" title="Zoom out">&#x2212;</button>
                            <span class="zoom-level">@((int)(ZoomLevel * 100))%</span>
                            <button class="btn-icon zoom-btn" @onclick="OnZoomIn" title="Zoom in">&#x002B;</button>
                            <button class="btn-icon zoom-btn" @onclick="OnZoomReset" title="Reset zoom">&#x21BA;</button>
                            <button class="btn-icon zoom-btn @(WrapText ? "active" : "")" @onclick="OnToggleWrap" title="Toggle word wrap">&#x21A9;</button>
                        </div>
                    </div>
                }
            </div>
        }
        else if (IsRightPanel)
        {
            <div style="display:flex;align-items:center;gap:8px;flex:1;overflow:hidden;padding:0 16px;">
                <span style="font-size:0.65rem;color:var(--text-muted);white-space:nowrap;">Tab:</span>
                <select class="tab-select" @onchange="OnRightTabSelected">
                    <option value="-1">— Select a file —</option>
                    @if (OpenTabs != null)
                    {
                        @foreach (var (t, i) in OpenTabs.Select((t, i) => (t, i)))
                        {
                            <option value="@i" selected="@(Tab?.Key == t.Key)">@t.FileName</option>
                        }
                    }
                </select>
            </div>
        }
        else
        {
            <span style="padding:0 20px;">Select a file to preview</span>
        }
    </div>

    @if (Tab?.Content != null)
    {
        <div class="viewer-content" @onscroll="OnScroll" style="position:relative;">
            <pre class="pre-line-numbers" style="font-size:@((ZoomLevel * 100).ToString("F0"))%;white-space:@(WrapText ? "pre-wrap" : "pre");">@Tab.Content</pre>
        </div>
        <div class="viewer-status">
            <span class="vs-line">Line @_scrollLine / @_totalLines</span>
            <span class="vs-scroll">@_scrollPercent%</span>
        </div>
    }
    else if (Tab?.IsLoading == true)
    {
        <div class="viewer-content">
            <div class="loading-overlay"><div class="spinner"></div><span class="loading-text">Loading content...</span></div>
        </div>
    }
    else if (Tab != null)
    {
        <div class="viewer-content">
            <div class="viewer-empty"><div class="empty-icon">&#x26A0;&#xFE0F;</div><div class="empty-title">Could not read file</div><div class="empty-desc">The entry may not be a text file or the archive password is incorrect.</div></div>
        </div>
    }
    else if (IsRightPanel)
    {
        <div class="viewer-content">
            <div class="viewer-empty"><div class="empty-icon">&#x1F4C4;</div><div class="empty-title">Select a file to view</div><div class="empty-desc">Pick a file from the dropdown above.</div></div>
        </div>
    }
    else
    {
        <div class="viewer-content">
            <div class="viewer-empty"><div class="empty-icon">&#x1F4C4;</div><div class="empty-title">Select a file to preview</div><div class="empty-desc">Choose a .txt entry from the contents panel.</div></div>
        </div>
    }
</div>
